{
  "manifest_version": 3,
  "name": "Nexa OS Companion",
  "version": "1.0.0",
  "description": "Integra la inteligencia de Nexa directamente en tus resultados de búsqueda de Google, Bing y DuckDuckGo.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.bing.com/*",
    "*://*.duckduckgo.com/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.google.com/search*",
        "*://*.bing.com/search*",
        "*://*.duckduckgo.com/*"
      ],
      "css": ["content.css"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Abrir Nexa"
  }
}
